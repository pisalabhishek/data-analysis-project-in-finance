      <aliases enabled='yes' />
      <column caption='Bad vs Good Loan (copy)' datatype='string' name='[Bad vs Good Loan (copy)_1012465534211661830]' role='dimension' type='nominal'>
        <calculation class='categorical-bin' column='[loan_status]' new-bin='true'>
          <bin default-name='false' value='&quot;Bad Loan&quot;'>
            <value>&quot;Charged Off&quot;</value>
          </bin>
          <bin default-name='false' value='&quot;Good Loan&quot;'>
            <value>&quot;Current&quot;</value>
            <value>&quot;Fully Paid&quot;</value>
          </bin>
        </calculation>
      </column>
      <column datatype='string' name='[Bad vs Good Loan]' role='dimension' type='nominal'>
        <calculation class='categorical-bin' column='[loan_status]' new-bin='true'>
          <bin default-name='false' value='&quot;Bad Loan&quot;'>
            <value>&quot;Charged Off&quot;</value>
          </bin>
          <bin default-name='false' value='&quot;Good Loan&quot;'>
            <value>&quot;Current&quot;</value>
            <value>&quot;Fully Paid&quot;</value>
          </bin>
        </calculation>
      </column>
      <column caption='Good Loan %' datatype='real' name='[Calculation_1012465534204997634]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT( IF [Bad vs Good Loan]= &apos;Good Loan&apos; THEN [id] END )&#13;&#10;/&#13;&#10;COUNT([id])' />
      </column>
      <column caption='Good Loan Applications' datatype='integer' name='[Calculation_1012465534206484483]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Bad vs Good Loan]=&apos;Good Loan&apos; THEN [id] END)' />
      </column>
      <column caption='Total Amount Received' datatype='integer' name='[Calculation_1139410746319323136]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_payment])' />
      </column>
      <column caption='Avg Interest rate' datatype='real' name='[Calculation_1139410746322001926]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([int_rate])' />
      </column>
      <column caption='Dynamic Measure' datatype='integer' name='[Calculation_2503157011160510464]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1]=&apos;Total Loan Applications&apos; THEN [Calculation_262616185237843968]&#13;&#10;ELSEIF [Parameters].[Parameter 1]=&apos;Total Funded Amount&apos; THEN [Calculation_541276420642295811]&#13;&#10;ELSEIF [Parameters].[Parameter 1]=&apos;Total Amount Received&apos; THEN [Calculation_1139410746319323136]&#13;&#10;END' />
      </column>
      <column caption='Total Loan Applications' datatype='integer' name='[Calculation_262616185237843968]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([id])' />
      </column>
      <column caption='MTD Loan Applications' datatype='integer' name='[Calculation_277534365836935168]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF &#13;&#10;DATEDIFF(&apos;month&apos;,[issue_date],{MAX([issue_date])})=0&#13;&#10;THEN&#13;&#10;[id]&#13;&#10;END     &#13;&#10;)' />
      </column>
      <column caption='Mom Loan App' datatype='real' name='[Calculation_541276420640911360]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_277534365836935168]-[MTD Loan Applications (copy)_541276420641222657])/[MTD Loan Applications (copy)_541276420641222657]' />
      </column>
      <column caption='Total Funded Amount' datatype='integer' name='[Calculation_541276420642295811]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([loan_amount])' />
      </column>
      <column caption='MoM Total Funded' datatype='real' name='[Calculation_541276420655501318]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([MTD Loan Applications (copy)_541276420654100484]-[MTD Total Funded Amount (copy)_541276420655226885])/[MTD Total Funded Amount (copy)_541276420655226885]' />
